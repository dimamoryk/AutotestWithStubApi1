server {
    listen 80 default_server;

    location / {
        proxy_pass http://selenoid_ui;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $host;
        proxy_buffering off;
    }

    location ~ /static/(js|css|media) {
        proxy_pass http://selenoid_ui;
    }

    location /status {
        proxy_pass http://selenoid_ui;
    }

    location /events {
        proxy_pass http://selenoid_ui;
    }

    location ~ /(logs|vnc)/ {
        proxy_pass http://selenoid_ui;
    }

    location ~ /wd/hub {
        proxy_pass http://ggr;
    }
}
